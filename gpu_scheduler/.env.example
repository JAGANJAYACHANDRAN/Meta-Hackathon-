# GPU Scheduler Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Your HuggingFace token (get one at https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# Environment server URL (HF Space or local)
IMAGE_NAME=https://PACMAN8055-gpu-scheduler-env.hf.space

# LLM API endpoint (default: HuggingFace inference router)
API_BASE_URL=https://router.huggingface.co/v1

# LLM model to use
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# --- Local Ollama (optional) ---
# IMAGE_NAME=http://127.0.0.1:8000
# API_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama3.1:8b
# API_KEY=ollama
# Omit HF_TOKEN when using Ollama (HF_TOKEN is checked first in inference.py).
